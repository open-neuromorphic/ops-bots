# .env.example
# ONM Discord Bot Configuration
# Copy this file to .env and fill in the values. NEVER commit .env to source control.

# Discord Bot Tokens
# Get this from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_TOKEN_SCRIBE=
DISCORD_TOKEN_CONTENT_OPS=
DISCORD_TOKEN_RESEARCH=

# GitHub Personal Access Token
# Needs repo read and issues read access to fetch docs and activity
GITHUB_TOKEN=
GITHUB_TOKEN_BOT=

# Fathom API Key
# Get this from your Fathom AI dashboard
FATHOM_API_KEY=

# Gemini / LLM Fallback (Cloud)
GEMINI_API_KEY=

# Local LLM Server Overrides (Tray App)
LLAMA_SERVER_BIN="~/Projects/llama.cpp/build/bin/llama-server"
LLAMA_MODEL_PATH="~/Projects/gemma-4-E4B_q4_0-it.gguf"

# Google Workspace / Docs
DOCUMENT_ID=

# Discord Role Permissions
# Comma-separated list of Discord Role IDs permitted to use specific bot scopes
EC_ADMIN_ROLE_IDS=
CONTEXT_ENGINE_ALLOWED_ROLE_IDS=
VOLUNTEER_TECHNICAL_ROLE_IDS=
VOLUNTEER_CONTENT_ROLE_IDS=